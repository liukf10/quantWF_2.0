# Function to safely handle NA/Inf values for plotting
safe_plot_data <- function(data, cols = c("log2FC", "p.adj")) {
  # Replace Inf/-Inf with NA
  for(col in cols) {
    if(col %in% colnames(data)) {
      data[[col]][is.infinite(data[[col]])] <- NA
    }
  }
  # Remove rows with NA in critical columns
  valid_rows <- complete.cases(data[, cols, drop = FALSE])
  return(data[valid_rows, ])
}

# Function to save plots as both PDF and PNG
# PDF saved to plot_dir, PNG saved to assets_dir (for report embedding)
save_plot_both <- function(plot, filename_base, width = 8, height = 6, dpi = 300) {
  pdf_file <- file.path(plot_dir, paste0(filename_base, ".pdf"))
  png_file <- file.path(assets_dir, paste0(filename_base, ".png"))
  
  # Save as PDF (high resolution for publication)
  pdf(pdf_file, width = width, height = height)
  print(plot)
  dev.off()
  
  # Save as PNG (for report embedding)
  png(png_file, width = width * dpi, height = height * dpi, res = dpi)
  print(plot)
  dev.off()
  
  return(list(pdf = pdf_file, png = png_file))
}

# Function to get label column for plotting
get_label_column <- function(result) {
  id_col <- "SYMBOL"
  
  # Check if IDinf exists and has the specified column
  if("IDinf" %in% ls() && !is.null(IDinf)) {
    if(!all(is.na(opt$idinf_col))) {
      # Try to find matching column in IDinf
      if(opt$idinf_col %in% colnames(IDinf)) {
        # Match rownames of IDinf with SYMBOL in result
        match_idx <- match(result$SYMBOL, rownames(IDinf))
        if(any(!is.na(match_idx))) {
          result$LABEL <- IDinf[match_idx, opt$idinf_col]
          # Only use LABEL if we got valid matches
          if(any(!is.na(result$LABEL))) {
            id_col <- "LABEL"
          }
        }
      }
    }
  }
  
  return(list(result = result, id_col = id_col))
}

# Function to create volcano plot
create_volcano_plot <- function(result, comp_name, log2FCcut, adjPcut, id_col = "SYMBOL") {
  # Clean data for plotting
  result <- safe_plot_data(result)
  
  if(nrow(result) == 0) {
    message("No valid data for volcano plot after removing NA/Inf values")
    return(NULL)
  }
  
  result$significance <- "Not Sig"
  result$significance[result$log2FC > log2FCcut & result$p.adj < adjPcut] <- "Up"
  result$significance[result$log2FC < -log2FCcut & result$p.adj < adjPcut] <- "Down"
  result$significance <- factor(result$significance, levels = c("Up", "Down", "Not Sig"))
  
  # Calculate y-axis limit, handling edge cases
  valid_pvals <- result$p.adj[!is.na(result$p.adj) & result$p.adj > 0 & !is.infinite(-log10(result$p.adj))]
  if(length(valid_pvals) == 0) {
    y_limit <- 10  # Default value
  } else {
    y_max <- max(-log10(valid_pvals), na.rm = TRUE)
    y_limit <- min(y_max * 1.1, 300)  # Cap at 300 for visibility
  }
  
  p <- ggplot(result, aes(x = log2FC, y = -log10(p.adj), color = significance)) +
    geom_point(alpha = 0.6, size = 1.5) +
    scale_color_manual(values = c("Up" = "#E41A1C", "Down" = "#377EB8", "Not Sig" = "grey50"),
                       labels = c("Up" = paste0("Up (", sum(result$significance == "Up", na.rm = TRUE), ")"),
                                  "Down" = paste0("Down (", sum(result$significance == "Down", na.rm = TRUE), ")"),
                                  "Not Sig" = "Not Significant")) +
    geom_vline(xintercept = c(-log2FCcut, log2FCcut), linetype = "dashed", color = "grey40") +
    geom_hline(yintercept = -log10(adjPcut), linetype = "dashed", color = "grey40") +
    coord_cartesian(ylim = c(0, y_limit)) +
    labs(title = paste0("Volcano Plot: ", comp_name),
         subtitle = paste0("log2FC cutoff: ", log2FCcut, ", adj.P cutoff: ", adjPcut),
         x = "Log2 Fold Change",
         y = "-Log10 Adjusted P-value",
         color = "Significance") +
    theme_bw() +
    theme(legend.position = "right",
          plot.title = element_text(hjust = 0.5, size = 14, face = "bold"),
          plot.subtitle = element_text(hjust = 0.5, size = 10))
  
  # Add labels for significant genes (top 20 by p-value)
  sig_genes <- result[result$significance %in% c("Up", "Down"), ]
  if(nrow(sig_genes) > 0) {
    # Sort by p.adj and get top 20
    sig_genes <- sig_genes[order(sig_genes$p.adj), ]
    top_genes <- head(sig_genes, 20)
    
    # Only add labels if we have valid labels
    if(id_col %in% colnames(top_genes) && any(!is.na(top_genes[[id_col]]))) {
      p <- p + geom_label_repel(
        data = top_genes,
        aes(label = !!sym(id_col)),
        size = 3,
        max.overlaps = 15,
        box.padding = 0.3,
        point.padding = 0.3,
        segment.size = 0.2,
        na.rm = TRUE
      )
    }
  }
  
  return(p)
}

# Function to create MA plot
create_ma_plot <- function(result, comp_name, log2FCcut, adjPcut, id_col = "SYMBOL") {
  # Clean data for plotting
  result <- safe_plot_data(result)
  
  if(nrow(result) == 0) {
    message("No valid data for MA plot after removing NA/Inf values")
    return(NULL)
  }
  
  # Calculate mean expression safely
  quant_subset <- quant[match(result$SYMBOL, rownames(quant)), , drop = FALSE]
  result$meanExpr <- rowMeans(quant_subset, na.rm = TRUE)
  
  result$significance <- "Not Sig"
  result$significance[result$log2FC > log2FCcut & result$p.adj < adjPcut] <- "Up"
  result$significance[result$log2FC < -log2FCcut & result$p.adj < adjPcut] <- "Down"
  result$significance <- factor(result$significance, levels = c("Up", "Down", "Not Sig"))
  
  p <- ggplot(result, aes(x = log2(meanExpr + 1), y = log2FC, color = significance)) +
    geom_point(alpha = 0.6, size = 1.5) +
    scale_color_manual(values = c("Up" = "#E41A1C", "Down" = "#377EB8", "Not Sig" = "grey50"),
                       labels = c("Up" = paste0("Up (", sum(result$significance == "Up", na.rm = TRUE), ")"),
                                  "Down" = paste0("Down (", sum(result$significance == "Down", na.rm = TRUE), ")"),
                                  "Not Sig" = "Not Significant")) +
    geom_hline(yintercept = c(-log2FCcut, log2FCcut), linetype = "dashed", color = "grey40") +
    labs(title = paste0("MA Plot: ", comp_name),
         subtitle = paste0("log2FC cutoff: ", log2FCcut, ", adj.P cutoff: ", adjPcut),
         x = "Log2 Mean Expression",
         y = "Log2 Fold Change",
         color = "Significance") +
    theme_bw() +
    theme(legend.position = "right",
          plot.title = element_text(hjust = 0.5, size = 14, face = "bold"),
          plot.subtitle = element_text(hjust = 0.5, size = 10))
  
  # Add labels for significant genes (top 20 by p-value)
  sig_genes <- result[result$significance %in% c("Up", "Down"), ]
  if(nrow(sig_genes) > 0) {
    # Sort by p.adj and get top 20
    sig_genes <- sig_genes[order(sig_genes$p.adj), ]
    top_genes <- head(sig_genes, 20)
    
    # Only add labels if we have valid labels
    if(id_col %in% colnames(top_genes) && any(!is.na(top_genes[[id_col]]))) {
      p <- p + geom_label_repel(
        data = top_genes,
        aes(label = !!sym(id_col)),
        size = 3,
        max.overlaps = 15,
        box.padding = 0.3,
        point.padding = 0.3,
        segment.size = 0.2,
        na.rm = TRUE
      )
    }
  }
  
  return(p)
}

