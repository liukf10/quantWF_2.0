# Function to determine input source (step1 or step2) based on filename and find corresponding report
find_prev_step_report <- function(input_file, outputdir, report_info = NULL) {
  if(is.na(input_file) || !file.exists(input_file)) {
    if(!is.null(report_info)) {
      report_info$prev_report_search <- "Input file not provided or does not exist"
    }
    return(list(report_path = NULL, prev_step = NULL, report_info = report_info))
  }
  
  # Determine source step based on filename patterns
  input_basename <- basename(input_file)
  if(grepl("_adj(_|final|obs|hid)", input_basename)) {
    prev_step <- "step2"
    step_suffix <- "_step2_report"
  } else if(grepl("_filter_|_norm_|_TMM|_quantile|_rmOut|_INT|_log_", input_basename)) {
    prev_step <- "step1"
    step_suffix <- "_step1_report"
  } else {
    # Default: try both
    prev_step <- "unknown"
    step_suffix <- NULL
  }
  
  # Extract base name from input file
  base_name <- sub("\\.RData$", "", basename(input_file))
  # Remove common step1/step2 suffixes to find original prefix
  base_name_alt <- sub("(_filter.*|_norm.*|_TMM.*|_quantile.*|_rmOut.*|_INT.*|_log.*|_adj.*|_step[12].*)", "", base_name)
  
  # Possible report file patterns
  if(!is.null(step_suffix)) {
    possible_reports <- c(
      file.path(outputdir, paste0(base_name, step_suffix, ".md")),
      file.path(outputdir, paste0(base_name_alt, step_suffix, ".md")),
      file.path(dirname(input_file), paste0(base_name, step_suffix, ".md")),
      file.path(dirname(input_file), paste0(base_name_alt, step_suffix, ".md"))
    )
  } else {
    # Try both step1 and step2 patterns
    possible_reports <- c(
      file.path(outputdir, paste0(base_name, "_step2_report.md")),
      file.path(outputdir, paste0(base_name, "_step1_report.md")),
      file.path(outputdir, paste0(base_name_alt, "_step2_report.md")),
      file.path(outputdir, paste0(base_name_alt, "_step1_report.md")),
      file.path(dirname(input_file), paste0(base_name, "_step2_report.md")),
      file.path(dirname(input_file), paste0(base_name, "_step1_report.md")),
      file.path(dirname(input_file), paste0(base_name_alt, "_step2_report.md")),
      file.path(dirname(input_file), paste0(base_name_alt, "_step1_report.md"))
    )
  }
  
  # Remove duplicates
  possible_reports <- unique(possible_reports)
  
  # Record search info
  search_info <- paste0("Detected input source: ", ifelse(prev_step == "unknown", "Unknown (trying both step1 and step2)", paste0("**", prev_step, "**")), "\n\n")
  search_info <- paste0(search_info, "Input file: `", input_file, "`\n\n")
  search_info <- paste0(search_info, "Base names tried: `", base_name, "`, `", base_name_alt, "`\n\n")
  search_info <- paste0(search_info, "Possible report paths checked:\n")
  
  for(report_path in possible_reports) {
    exists_flag <- file.exists(report_path)
    status_symbol <- ifelse(exists_flag, "✓ Found", "✗ Not found")
    search_info <- paste0(search_info, "- `", report_path, "` ", status_symbol, "\n")
    if(exists_flag) {
      message("Found previous step report: ", report_path)
      # Update prev_step based on found report
      if(grepl("step2", report_path)) prev_step <- "step2"
      else if(grepl("step1", report_path)) prev_step <- "step1"
      if(!is.null(report_info)) {
        report_info$prev_report_search <- search_info
        report_info$prev_report_found <- report_path
        report_info$prev_step <- prev_step
      }
      return(list(report_path = report_path, prev_step = prev_step, report_info = report_info))
    }
  }
  
  message("No previous step report found for: ", input_file)
  if(!is.null(report_info)) {
    report_info$prev_report_search <- search_info
    report_info$prev_report_found <- NULL
    report_info$prev_step <- prev_step
  }
  return(list(report_path = NULL, prev_step = prev_step, report_info = report_info))
}

