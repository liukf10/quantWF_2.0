# Function to save plots as both PDF and PNG
save_plot_both <- function(plot_func, filename_base, width = 10, height = 8, dpi = 300, ...) {
  pdf_file <- file.path(plot_dir, paste0(filename_base, ".pdf"))
  png_file <- file.path(plot_dir, paste0(filename_base, ".png"))
  
  # Save as PDF
  pdf(pdf_file, width = width, height = height)
  plot_func(...)
  dev.off()
  
  # Save as PNG
  png(png_file, width = width * dpi, height = height * dpi, res = dpi)
  plot_func(...)
  dev.off()
  
  return(list(pdf = pdf_file, png = basename(png_file)))
}

