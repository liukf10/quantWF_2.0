  if(covar_exists) {
    write_report(paste0("## 3. Module-Trait Relationships\n\n"))
    write_report(paste0("**Covariate data available:** YES\n\n"))
    write_report(paste0("- Number of traits analyzed: ", ncol(covar), "\n\n"))
    write_report(paste0("- Traits: ", paste(colnames(covar), collapse = ", "), "\n\n"))
    
    # Calculate module-trait correlations
    MEs <- orderMEs(CoExpNet$MEs)
    covar_numeric <- covar
    for(i in 1:ncol(covar_numeric)) {
      if(is.factor(covar_numeric[[i]]) || is.character(covar_numeric[[i]])) {
        covar_numeric[[i]] <- as.numeric(as.factor(covar_numeric[[i]]))
      }
    }
    moduleTraitCor <- cor(MEs, covar_numeric, use = "p")
    moduleTraitPvalue <- corPvalueStudent(moduleTraitCor, nrow(wgcnadata))
    
    write_report(paste0("### Significant Module-Trait Correlations (p < 0.05)\n\n"))
    sig_count <- 0
    sig_results <- data.frame(Module = character(), Trait = character(), Correlation = numeric(), Pvalue = numeric(), stringsAsFactors = FALSE)
    for(i in 1:nrow(moduleTraitCor)) {
      for(j in 1:ncol(moduleTraitCor)) {
        if(moduleTraitPvalue[i,j] < 0.05) {
          sig_count <- sig_count + 1
          sig_results <- rbind(sig_results, data.frame(
            Module = rownames(moduleTraitCor)[i],
            Trait = colnames(moduleTraitCor)[j],
            Correlation = round(moduleTraitCor[i,j], 3),
            Pvalue = format(moduleTraitPvalue[i,j], digits = 3, scientific = TRUE)
          ))
        }
      }
    }
    if(sig_count == 0) {
      write_report(paste0("No significant module-trait correlations found.\n\n"))
    } else {
      write_report(paste0("| Module | Trait | Correlation | P-value |\n"))
      write_report(paste0("|--------|-------|-------------|---------|\n"))
      for(i in 1:nrow(sig_results)) {
        write_report(paste0("| ", sig_results$Module[i], " | ", sig_results$Trait[i], 
                           " | ", sig_results$Correlation[i], " | ", sig_results$Pvalue[i], " |\n"))
      }
      write_report(paste0("\n**Total significant correlations:** ", sig_count, "\n\n"))
    }
    write_report(paste0("### Module-Trait Heatmap\n\n"))
    write_report(paste0("![Module-Trait Heatmap](plot/Module_trait_heatmap_", output, ".png)\n\n"))
    write_report(paste0("*Files: Module_trait_heatmap_", output, ".pdf / .png*\n\n"))
  }
  
  loginfo1 = list(record = paste0(record1,
                                  "do WGCNA and draw regular WGCNA plot.\n"),
                  input = opt$input,
                  output = file.path(opt$outputdir, paste0(opt$output,"_WGCNAnet.Rdata")),
                  sessionInfo = sessionInfo(),
                  srcipt = "step3_WGCNA_R v1.1", parameter = opt,
                  running_time = Sys.time())
  
  loginfo = c(loginfo, step3_WGCNA_R = list(loginfo1))
  
  save(CoExpNet, MEinf, moduleinf,loginfo,report_file,list=otherobj, 
       file = file.path(opt$outputdir, paste0(opt$output,"_WGCNAnet.Rdata")))
  
  # Report: Plots section
  write_report(paste0("## 4. Visualization\n\n"))
  write_report(paste0("Generated plots (both PDF and PNG formats):\n\n"))
  write_report(paste0("### Module Dendrogram and Colors\n\n"))
  write_report(paste0("![Module Dendrogram](plot/", opt$output, "_WGCNA.png)\n\n"))
  write_report(paste0("*Files: ", opt$output, "_WGCNA.pdf / .png*\n\n"))
  
  # Report: File summary
  write_report(paste0("## 5. Generated Files Summary\n\n"))
  write_report(paste0("### Main Output Files\n\n"))
  write_report(paste0("| File | Description |\n"))
  write_report(paste0("|------|-------------|\n"))
  write_report(paste0("| ", opt$output, "_WGCNAnet.Rdata | Main WGCNA results (CoExpNet, MEinf, moduleinf) |\n"))
  write_report(paste0("| ", opt$output, "_WGCNA_module_gene_info.csv | Module gene assignments |\n"))
  write_report(paste0("| ", opt$output, "_WGCNA_ME_matrix.csv | Module eigengene matrix |\n"))
  
  output_files <- c(
    paste0("SoftThershold_", opt$output, ".pdf"),
    paste0("Module_trait_heatmap_", opt$output, ".pdf"),
    paste0(opt$output, "_WGCNA.pdf")
  )
  
  # Check which files actually exist
  existing_files <- sapply(output_files, function(f) file.exists(file.path(plot_dir, f)))
  
  for(i in seq_along(output_files)) {
    if(existing_files[i]) {
      base_name <- tools::file_path_sans_ext(output_files[i])
      write_report(paste0("| plot/", base_name, ".pdf/png | Visualization plot |\n"))
    }
  }
  
  if(opt$tuning && file.exists(file.path(opt$outputdir, paste0(opt$output, "_WGCNAadjust.csv")))) {
    write_report(paste0("| ", opt$output, "_WGCNAadjust.csv | Parameter tuning results |\n"))
  }
  
  write_report(paste0("\n### Report File\n\n"))
  write_report(paste0("- ", basename(report_file), "\n\n"))
  write_report(paste0("---\n\n"))
  write_report(paste0("**WGCNA Analysis Completed**\n\n"))
  write_report(paste0("End Time: ", Sys.time(), "\n"))
  
  rm(input)
  if(length(unique(moduleinf$moduleNum)) != 1) {
    output = opt$output
    source(funcpath)
  } else message("No module detect, No WGCNA plot.")
  print(table(moduleinf$moduleNum))
} else {
  message("onlytune, see SoftThershold_xx.pdf or xx_WGCNAadjust.csv to see the parameter.")
  
  # Report for onlytune mode
  write_report(paste0("## Parameter Tuning Mode Only\n\n"))
  write_report(paste0("**Mode:** onlytune = TRUE\n\n"))
  write_report(paste0("No module detection was performed.\n\n"))
  write_report(paste0("### Generated Files\n\n"))
  if(file.exists(file.path(plot_dir, paste0("SoftThershold_", output, ".pdf")))) {
    write_report(paste0("- SoftThershold_", output, ".pdf / .png\n\n"))
  }
  if(file.exists(file.path(opt$outputdir, paste0(opt$output, "_WGCNAadjust.csv")))) {
    write_report(paste0("- ", opt$output, "_WGCNAadjust.csv\n\n"))
  }
  write_report(paste0("---\n\n"))
  write_report(paste0("**WGCNA Tuning Completed**\n\n"))
  write_report(paste0("End Time: ", Sys.time(), "\n"))
}
