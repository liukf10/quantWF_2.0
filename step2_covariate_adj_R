### Helper function: Find input report based on quantfile ####
find_input_report <- function(quantfile, outputdir, report_info = NULL) {
  if(is.na(quantfile) || !file.exists(quantfile)) {
    if(!is.null(report_info)) {
      report_info$step1_report_search <- "Quantfile not provided or does not exist"
    }
    return(list(report_path = NULL, report_info = report_info))
  }
  # Extract base name from quantfile (remove .RData extension)
  base_name <- sub("\\.RData$", "", basename(quantfile))
  # Also try removing common step1 suffixes
  base_name_alt <- sub("(_filter|_norm|_TMM|_quantile|_rmOut|_log|_INT|_step1).*", "", base_name)
  
  # Possible report file patterns
  possible_reports <- c(
    file.path(outputdir, paste0(base_name, "_step1_report.md")),
    file.path(outputdir, paste0(base_name, "_report.md")),
    file.path(dirname(quantfile), paste0(base_name, "_step1_report.md")),
    file.path(dirname(quantfile), paste0(base_name, "_report.md")),
    # Alternative base names
    file.path(outputdir, paste0(base_name_alt, "_step1_report.md")),
    file.path(outputdir, paste0(base_name_alt, "_report.md")),
    file.path(dirname(quantfile), paste0(base_name_alt, "_step1_report.md")),
    file.path(dirname(quantfile), paste0(base_name_alt, "_report.md"))
  )
  
  # Remove duplicates
  possible_reports <- unique(possible_reports)
  
  # Record search info
  search_info <- paste0("Searching for step1 report based on quantfile: `", quantfile, "`\n\n")
  search_info <- paste0(search_info, "Base names tried: `", base_name, "`, `", base_name_alt, "`\n\n")
  search_info <- paste0(search_info, "Possible report paths checked:\n")
  
  for(report_path in possible_reports) {
    exists_flag <- file.exists(report_path)
    search_info <- paste0(search_info, "- `", report_path, "` ", ifelse(exists_flag, "âœ“ Found", "âœ— Not found"), "\n")
    if(exists_flag) {
      message("Found step1 report: ", report_path)
      if(!is.null(report_info)) {
        report_info$step1_report_search <- search_info
        report_info$step1_report_found <- report_path
      }
      return(list(report_path = report_path, report_info = report_info))
    }
  }
  
  message("No step1 report found for: ", quantfile)
  if(!is.null(report_info)) {
    report_info$step1_report_search <- search_info
    report_info$step1_report_found <- NULL
  }
  return(list(report_path = NULL, report_info = report_info))
}

