    message("quant_raw is not available or empty, skipping BIC plot.")
    valid_bicdata <- FALSE
  } else if(is.null(covar) || nrow(covar) == 0) {
    message("covar is empty, skipping BIC plot.")
    valid_bicdata <- FALSE
  }
  # Check specific quant objects based on adjcov
  if(valid_bicdata && opt$adjcov %in% c("obs", "obs&hid", "obs+hid")) {
    if(!exists("quant1") || is.null(quant1) || nrow(quant1) == 0 || ncol(quant1) == 0) {
      message("quant1 (observed adjusted) is not available or empty, skipping BIC plot.")
      valid_bicdata <- FALSE
    }
  }
  if(valid_bicdata && opt$adjcov %in% c("hid", "obs&hid", "obs+hid")) {
    if(!exists("quant") || is.null(quant) || nrow(quant) == 0 || ncol(quant) == 0) {
      message("quant (hidden adjusted) is not available or empty, skipping BIC plot.")
      valid_bicdata <- FALSE
    }
  }
  
  if(valid_bicdata) {
  plotpdfname = paste0("_step2_",opt$adjcov)
  BIClist <- list(adjust_before =quant_raw,
                  adjust_observed = quant1,
                  adjust_hidden = quant)
  if(opt$adjcov == "obs") BIClist <- BIClist[-3]
  if(opt$adjcov == "obs&hid") BIClist <- BIClist[-2] 
  
  # Remove NULL elements from BIClist
  BIClist <- BIClist[!sapply(BIClist, is.null)]
  
  if(length(BIClist) == 0) {
    message("No valid data for BIC evaluation. Skipping BIC plot.")
  } else {
    cat("- Draw BIC plot - \n")
    cat("Note: BIC evaluation may take a long time depending on the number of features and cores used.\n")
    
    bic_pdf <- file.path(plot_dir, paste0(opt$output,plotpdfname,"_bic.pdf"))
    
    # Save as PDF
    pdf(bic_pdf,width = 12,height = 6)
    BICresult_list <- list()
    for(i in names(BIClist)) {
      if(!is.null(BIClist[[i]]) && nrow(BIClist[[i]]) > 0 && ncol(BIClist[[i]]) > 0) {
        BICresult <- BIC_evaluate(BIClist[[i]],covar,num_cores = opt$BIC_cores,output = paste0("BIC estimation (",i,")"))
        BICresult_list[[i]] <- BICresult$BICres
        print(BICresult$pic)
      } else {
        message(paste0("Skipping BIC for '", i, "': data is empty."))
      }
    }
    dev.off()
    
    # Save as PNG - separate files for each plot
    for(i in names(BIClist)) {
      if(!is.null(BIClist[[i]]) && nrow(BIClist[[i]]) > 0 && ncol(BIClist[[i]]) > 0) {
        bic_png_file <- file.path(assets_dir, paste0(opt$output,plotpdfname,"_bic_",i,".png"))
        png(bic_png_file,width = 1200,height = 600,res = 150)
        BICresult <- BIC_evaluate(BIClist[[i]],covar,num_cores = opt$BIC_cores,output = paste0("BIC estimation (",i,")"))
        print(BICresult$pic)
        dev.off()
      }
    }
    
    if(length(BICresult_list) > 0) {
      save(BICresult_list,file = file.path(opt$outputdir, paste0(opt$output,plotpdfname,"_BIC.RData")) )
      message("BIC plot was finished.")
    } else {
      message("No BIC results were generated.")
    }
  }
  }  # end if(valid_bicdata)
}  # end if(grepl("bic|BIC",opt$evaluate_method))

