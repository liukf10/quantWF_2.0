# V2.1: Helper function to safely generate density plot
safe_densityplot <- function(data, title, png_path, ...) {
  png(png_path, width = 12*300, height = 10*300, res = 300)
  plot_success <- tryCatch({
    densityplot(data, title, savefile = FALSE, ...)
    TRUE
  }, error = function(e) {
    message("Density plot failed for '", title, "': ", e$message)
    FALSE
  })
  dev.off()
  # Remove empty/invalid PNG file if plot failed
  if(!plot_success && file.exists(png_path)) {
    file.remove(png_path)
    return(NULL)
  }
  return(if(plot_success) png_path else NULL)
}

