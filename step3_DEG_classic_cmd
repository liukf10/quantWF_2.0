### Function to find previous step report ####
find_prev_step_report <- function(input_file, outputdir) {
  if(is.na(input_file) || !file.exists(input_file)) {
    return(list(report_path = NULL, prev_step = NULL))
  }
  input_basename <- basename(input_file)
  if(grepl("_adj(_|final|obs|hid)", input_basename)) {
    prev_step <- "step2"
    step_suffix <- "_step2_report"
  } else if(grepl("_filter_|_norm_|_TMM|_quantile|_rmOut|_INT|_log_", input_basename)) {
    prev_step <- "step1"
    step_suffix <- "_step1_report"
  } else {
    prev_step <- "unknown"
    step_suffix <- NULL
  }
  
  report_path <- NULL
  if(!is.null(step_suffix)) {
    # First check: try to derive report name from input filename
    # Remove common data suffixes and add report suffix
    input_base <- sub("\\.RData$", "", input_basename)
    
    # Try different patterns to find the report
    possible_reports <- c(
      file.path(outputdir, paste0(input_base, "_report.md")),
      file.path(outputdir, paste0(input_base, step_suffix, ".md"))
    )
    
    # Also try to find any report file with step suffix in outputdir
    if(dir.exists(outputdir)) {
      all_files <- list.files(outputdir, pattern = paste0(step_suffix, "\\.md$"), full.names = TRUE)
      if(length(all_files) > 0) {
        # Sort by modification time and take the most recent
        file_info <- file.info(all_files)
        most_recent <- all_files[which.max(file_info$mtime)]
        possible_reports <- c(possible_reports, most_recent)
      }
    }
    
    # Find the first existing report
    for(report_candidate in possible_reports) {
      if(file.exists(report_candidate)) {
        report_path <- report_candidate
        break
      }
    }
  }
  
  return(list(report_path = report_path, prev_step = prev_step))
}

