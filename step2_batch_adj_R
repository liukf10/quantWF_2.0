# Helper function to save plots as both PDF and PNG
save_plot_both <- function(plot_expr, pdf_path, png_path, pdf_width, pdf_height, png_width = pdf_width * 100, png_height = pdf_height * 100, png_res = 150) {
  # Save as PDF
  pdf(pdf_path, width = pdf_width, height = pdf_height)
  eval(plot_expr)
  dev.off()
  
  # Save as PNG
  png(png_path, width = png_width, height = png_height, res = png_res)
  eval(plot_expr)
  dev.off()
}

