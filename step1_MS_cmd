# Function to find step0 report based on quantfile
find_step0_report <- function(quantfile, outputdir) {
  if(is.na(quantfile) || !file.exists(quantfile)) {
    return(NULL)
  }
  # Extract base name from quantfile (remove extension)
  base_name <- sub("\\.(txt|csv|RData)$", "", basename(quantfile))
  # Also try removing common suffixes
  base_name_alt <- sub("(_raw|_step0).*", "", base_name)
  
  # Possible report file patterns for step0
  possible_reports <- c(
    file.path(outputdir, paste0(base_name, "_step0_report.md")),
    file.path(outputdir, paste0(base_name, "_report.md")),
    file.path(dirname(quantfile), paste0(base_name, "_step0_report.md")),
    file.path(dirname(quantfile), paste0(base_name, "_report.md")),
    # Alternative base names
    file.path(outputdir, paste0(base_name_alt, "_step0_report.md")),
    file.path(outputdir, paste0(base_name_alt, "_report.md")),
    file.path(dirname(quantfile), paste0(base_name_alt, "_step0_report.md")),
    file.path(dirname(quantfile), paste0(base_name_alt, "_report.md"))
  )
  
  # Remove duplicates and check existence
  possible_reports <- unique(possible_reports)
  for(report_path in possible_reports) {
    if(file.exists(report_path)) {
      message("Found step0 report: ", report_path)
      return(report_path)
    }
  }
  message("No step0 report found for: ", quantfile)
  return(NULL)
}

